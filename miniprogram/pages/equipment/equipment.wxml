<view class="container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="goBack">
      <text>←</text>
    </view>
    <text class="nav-title-text">装备管理</text>
  </view>

  <!-- 内容区域 -->
  <scroll-view class="content" scroll-y>

    <!-- 类别选择 -->
    <view class="category-section">
      <view class="category-list">
        <view
          wx:for="{{categories}}"
          wx:key="value"
          class="category-item {{selectedCategory === item.value ? 'active' : ''}}"
          bindtap="onCategoryChange"
          data-value="{{item.value}}"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 装备列表 -->
    <view class="equipment-section">
      <view class="section-header">
        <text class="section-title">我的装备</text>
        <text class="add-btn" bindtap="toggleAddForm">{{showAddForm ? '取消' : '+ 添加'}}</text>
      </view>

      <!-- 添加表单 -->
      <view class="add-form" wx:if="{{showAddForm}}">
        <view class="form-row">
          <input
            class="form-input"
            placeholder="装备名称"
            value="{{newEquipmentName}}"
            bindinput="onNameInput"
          />
        </view>
        <view class="form-row">
          <input
            class="form-input"
            placeholder="备注（选填）"
            value="{{newEquipmentNotes}}"
            bindinput="onNotesInput"
          />
        </view>
        <button class="save-btn" bindtap="onSaveEquipment">保存</button>
      </view>

      <!-- 列表 -->
      <view class="equipment-list" wx:if="{{equipmentList.length > 0}}">
        <view
          wx:for="{{equipmentList}}"
          wx:key="id"
          class="equipment-item"
        >
          <view class="equipment-info">
            <text class="equipment-name">{{item.name}}</text>
            <text class="equipment-category">{{item.category === 'shoes' ? '攀岩鞋' : item.category === 'chalk' ? '镁粉' : item.category === 'rope' ? '绳索' : item.category === 'quickdraw' ? '锁具' : item.category === 'trad' ? '扁带' : item.category === 'harness' ? '安全带' : item.category === 'helmet' ? '头盔' : '其他'}}</text>
            <text class="equipment-notes" wx:if="{{item.notes}}">{{item.notes}}</text>
          </view>
          <view class="equipment-delete" catchtap="onDeleteEquipment" data-id="{{item.id}}">
            <text>删除</text>
          </view>
        </view>
      </view>

      <view class="empty-tip" wx:else>
        <text>暂无装备，点击右上角添加</text>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="bottom-space"></view>
  </scroll-view>
</view>
